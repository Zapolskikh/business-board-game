{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend: run API (uvicorn)",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe -m uvicorn app.main:app --reload --port 8000",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "isBackground": true,
      "problemMatcher": [],
      "group": "none"
    },
    {
      "label": "backend: run tests (pytest)",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe -m pytest",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "simulation: production smoke (10 games)",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe -m simulation.cli --games=10 --rounds=15 --players=4 --role-price=3 --bots=easy,medium,medium,hard --workers=2",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "frontend: dev server (vite)",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "frontend: install deps",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "problemMatcher": []
    }
  ]
}
